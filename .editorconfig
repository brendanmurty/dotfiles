# EditorConfig - https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
max_line_length = 100

[*.{md,json,jsonc,toml,yml}]
insert_final_newline = false

[{Dockerfile,.editorconfig,.gitignore,.gitmodules,.npmrc}]
insert_final_newline = false

[{justfile}]
indent_style = space
insert_final_newline = false

[{*.sh,*.bash}]
insert_final_newline = false