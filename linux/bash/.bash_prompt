#
#
# ~/.bash_prompt
#   - Customised shell prompt
#   - Relies on the '__git_ps1' script from the official Git repo:
#     https://raw.githubusercontent.com/git/git/refs/heads/master/contrib/completion/git-prompt.sh
#
#

# Blue shades - text only
PROMPT_COMMAND='PS1_CMD1=$(__git_ps1 " %s")';
PS1=$'\[$(tput setaf 241)\]\D{%I:%M:%S} \[$(tput setaf 159)\]\w\[$(tput setaf 45)\]${PS1_CMD1}\[$(tput sgr0)\]\n\[$(tput setaf 241)\]> \[$(tput sgr0)\]';

# Blue shades - with unicode characters as icons
# PROMPT_COMMAND='PS1_CMD1=$(__git_ps1 " \u22A9 %s")';
# PS1=$'\[$(tput setaf 241)\]\u2D32 \D{%I:%M:%S} \[$(tput setaf 246)\]\u2302 \w \[$(tput setaf 159)\]${PS1_CMD1}\w\[$(tput setaf 45)\]${PS1_CMD1}\[$(tput sgr0)\]\n\[$(tput setaf 241)\]> \[$(tput sgr0)\]';

