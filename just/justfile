#!/usr/bin/env just --justfile
#
#
# Just command runner configuration
#   - Initial setup: bash ./setup-just-commands-user.sh
#   - Then you can run from any directory (lists all options): ujust
#   - More info at https://github.com/casey/just
#
#

# Set default config

set shell := ["bash", "-uc"]
set ignore-comments := true
set quiet := true

# Add alias commands

alias help := list
alias ls := list
alias menu := choose

# Default to the 'list' command, when 'just' is run without any parameters
default: list

# Show a graphical selector listing the available options and their script content
choose:
  @just --choose --justfile "{{ justfile() }}"

# Show a list of the available 'run' commands
list:
  @echo '{{ style("warning") }}Listing "just" command options from {{ justfile() }}{{ NORMAL }}'
  just --justfile "{{ justfile() }}" --list --alias-style 'right' --list-heading '' --list-prefix ''

# Get the OS name
[group('system')]
os:
  #!/usr/bin/env bash
  OS_NAME="$(uname -s)";
  if [[ "$OS_NAME" == 'Freedesktop SDK' ]]; then
    echo "Linux";
  elif [[ "$OS_NAME" == 'Linux' ]]; then
    echo "$(source /etc/os-release && echo $NAME)";
  elif [[ "$OS_NAME" == 'Darwin' ]]; then
    echo 'macOS';
  elif [[ "$OS_NAME" == 'CYGWIN' ]]; then
    echo 'Windows';
  elif [[ "$OS_NAME" == 'MINGW' ]]; then
    echo 'Windows';
  elif [[ "$OS_NAME" == 'MSYS_NT' ]]; then
    echo 'Windows';
  else
    echo "${OS_NAME}";
  fi

# List local users
[group('system')]
users:
  awk -F: '$3 >= 1000 && $1 != "nobody" && $0="user: " $1 "   id: " $3 "   home: " $6' /etc/passwd

# Find which processes are using a certain port number
[group('system')]
[positional-arguments]
port port_number:
  sudo lsof -i ":{{ port_number }}" || echo "Port doesn't seem to be in use"

# Run 'backup-user' script
[group('tools')]
backup:
  bash "$HOME/Dotfiles/storage/backup-user/backup-user.sh"

# Return your machine's public IP address
[group('tools')]
ip:
  dig +short myip.opendns.com @resolver1.opendns.com

# Update system packages and apps
[group('system')]
update:
  #!/usr/bin/env bash
  OS=$(just os);
  if [[ "$OS" == 'Ubuntu' ]]; then
    echo '=> Ubuntu: Updating APT packages';
    sudo apt update -y -qq;
    sudo apt upgrade -y -qq;
    sudo apt full-upgrade -y -qq;
  elif [[ "$OS" == 'EndeavourOS' ]]; then
    echo '=> EndeavourOS: Running "eos-update"';
    eos-update --aur;
  fi
  if command -v snap >/dev/null 2>&1 ; then
    echo '=> Snap: Updating packages';
    sudo snap refresh;
  fi
  if command -v flatpak >/dev/null 2>&1 ; then
    echo '=> Flatpak: Updating packages';
    flatpak update -y;
  fi
  if command -v brew >/dev/null 2>&1 ; then
    echo '=> Homebrew: Updating packages';
    brew update;
    brew upgrade;
  fi

# Clean packages and temp files
[group('system')]
clean:
  #!/usr/bin/env bash
  OS=$(just os);
  if [[ "$OS" == 'Ubuntu' ]]; then
    echo '=> Ubuntu: Cleanup APT packages';
    sudo apt autoremove -y;
    sudo apt clean -y;
    sudo apt autoclean -y;
  fi
  if command -v flatpak >/dev/null 2>&1 ; then
    echo '=> Flatpack: Cleanup packages';
    flatpak uninstall -y --unused --delete-data;
  fi
  if command -v brew >/dev/null 2>&1 ; then
    echo '=> Homebrew: Cleanup packages';
    brew cleanup;
  fi
  if command -v snap >/dev/null 2>&1 ; then
    echo '=> Snap: Cleanup packages';
    sudo snap set system refresh.retain=2;
    sudo rm -rf /var/lib/snapd/cache/*;
  fi

# Info about Just and the system
[group('info')]
info:
  @echo "$( just --version )"
  @echo "OS: $( just os )"
  @echo "Architecture: {{ arch() }}"
  @echo "Process: {{ just_pid() }}"
  @echo "Binary: {{ just_executable() }}"
  @echo "Config: {{ justfile() }}"
  @echo "Current Dir: {{ invocation_directory() }}"
