#
#
# ~/.bash_prompt
#   - Customised shell prompt
#   - Loaded from '~/.bash_profile'
#		- Helpful tools:
#			 - https://robotmoon.com/bash-prompt-generator/
#      - https://bash-prompt-generator.org/
#   - Relies on the '__git_ps1' script from the official Git repo:
#     https://raw.githubusercontent.com/git/git/refs/heads/master/contrib/completion/git-prompt.sh
#
#

### Text only
# (date current_dir git_branch new_line > space)
PROMPT_COMMAND='PS1_CMD1=$(__git_ps1 " %s")';

#### Colours - Blues
PS1=$'\[$(tput setaf 242)\]\D{%I:%M:%S} \[$(tput setaf 247)\]\u \h\[$(tput sgr0)\] \[$(tput setaf 159)\]\w\[$(tput setaf 45)\]${PS1_CMD1}\[$(tput sgr0)\]\n\[$(tput setaf 242)\]> \[$(tput sgr0)\]';

#### Colours - Oranges
# PS1='\[$(tput setaf 243)\]\D{%I:%M:%S} \[$(tput setaf 214)\]\w\[$(tput setaf 173)\]${PS1_CMD1}\[$(tput sgr0)\]\n\[$(tput setaf 243)\]> \[$(tput sgr0)\]';

### Text with unicode characters as icons
# (icon date icon current_dir icon git_branch new_line > space)
# PROMPT_COMMAND='PS1_CMD1=$(__git_ps1 " \u22A9 %s")';

##### Colours - Blues
# PS1=$'\[$(tput setaf 241)\]\u2D32 \D{%I:%M:%S} \[$(tput setaf 246)\]\u2302 \w \[$(tput setaf 159)\]${PS1_CMD1}\w\[$(tput setaf 45)\]${PS1_CMD1}\[$(tput sgr0)\]\n\[$(tput setaf 241)\]> \[$(tput sgr0)\]';

##### Colours - Oranges
# PS1=$'\[$(tput setaf 243)\]\u2D32 \D{%I:%M:%S}  \[$(tput setaf 214)\]\u29c8 \w \[$(tput setaf 173)\]${PS1_CMD1}\[$(tput sgr0)\]\n\[$(tput setaf 243)\]> \[$(tput sgr0)\]';
