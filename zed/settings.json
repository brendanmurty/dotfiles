{
  "cli_default_open_behavior": "existing_window",
  "ensure_final_newline_on_save": false,
  "zoomed_padding": false,
  "window_decorations": "client",
  "bottom_dock_layout": "contained",
  "current_line_highlight": "gutter",
  "status_bar": {
    "active_language_button": true,
    "show_active_file": true,
    "active_encoding_button": "disabled",
  },
  "show_wrap_guides": true,
  "restore_on_startup": "launchpad",
  "session": {
    "trust_all_worktrees": true,
  },
  "context_servers": {},
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
  },
  "hover_popover_enabled": false,
  "close_on_file_delete": false,
  "when_closing_with_no_tabs": "keep_window_open",
  "selection_highlight": true,
  "rounded_selection": false,
  "middle_click_paste": false,
  "diagnostics_max_severity": "warning",
  "confirm_quit": true,
  "ui_font_family": ".ZedSans",
  "ui_font_weight": 500.0,
  "agent_ui_font_size": 18.0,
  "agent_buffer_font_size": 18.0,
  "languages": {
    "Desktop Entry": {
      "format_on_save": "off",
      "auto_indent_on_paste": false,
      "auto_indent": "none",
      "tab_size": 2,
      "ensure_final_newline_on_save": false,
    },
    "ini": {
      "format_on_save": "off",
      "auto_indent_on_paste": false,
      "auto_indent": "none",
      "tab_size": 2,
      "ensure_final_newline_on_save": false,
    },
    "JSON": {
      "format_on_save": "on",
      "auto_indent_on_paste": true,
      "auto_indent": "syntax_aware",
      "tab_size": 2,
      "ensure_final_newline_on_save": false,
    },
    "JSONC": {
      "format_on_save": "on",
      "auto_indent_on_paste": true,
      "auto_indent": "syntax_aware",
      "tab_size": 2,
      "ensure_final_newline_on_save": false,
    },
    "Shell Script": {
      "format_on_save": "on",
      "auto_indent_on_paste": true,
      "auto_indent": "syntax_aware",
      "tab_size": 2
    },
    "Just": {
      "format_on_save": "on",
      "auto_indent_on_paste": true,
      "auto_indent": "syntax_aware",
      "tab_size": 2,
      "language_servers": [
        "!just-lsp"
      ]
    },
    "Python": {
      "format_on_save": "on",
      "auto_indent_on_paste": true,
      "auto_indent": "syntax_aware",
      "tab_size": 2
    },
    "YAML": {
      "format_on_save": "off",
      "auto_indent_on_paste": true,
      "auto_indent": "none",
      "tab_size": 2,
      "ensure_final_newline_on_save": false
    }
  },
  "outline_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
  },
  "use_auto_surround": false,
  "use_autoclose": false,
  "preferred_line_length": 125,
  "soft_wrap": "preferred_line_length",
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true,
  },
  "tabs": {
    "show_close_button": "hidden",
    "show_diagnostics": "errors",
    "activate_on_close": "left_neighbour",
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "inlay_hints": {
    "enabled": true,
    "edit_debounce_ms": 500,
    "scroll_debounce_ms": 500,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "toggle_on_modifiers_press": {
      "control": false,
      "shift": false,
      "alt": true,
      "platform": false,
      "function": false,
    },
  },
  "preview_tabs": {
    "enable_preview_file_from_code_navigation": false,
    "enable_preview_from_multibuffer": false,
    "enable_preview_from_project_panel": false,
    "enabled": false,
  },
  "seed_search_query_from_cursor": "selection",
  "search": {
    "button": true,
    "center_on_match": true,
  },
  "indent_guides": {
    "background_coloring": "disabled",
    "enabled": true,
    "coloring": "disabled",
  },
  "message_editor": {
    "auto_replace_emoji_shortcode": false,
  },
  "autosave": "off",
  "show_whitespaces": "trailing",
  "whitespace_map": {
    "space": "•",
    "tab": "→",
  },
  "tab_size": 2,
  "edit_predictions": {
    "disabled_globs": [
      "~/.**",
      "**/.env",
      "**/.env.*",
      "**/.pem",
      "**/.key",
      "**/.cert",
      "**/.crt",
      "**/secrets.*",
      "**/secrets*",
    ],
    "mode": "subtle",
  },
  "toolbar": {
    "breadcrumbs": false,
    "code_actions": true,
    "quick_actions": false,
    "selections_menu": true,
    "agent_review": true,
  },
  "minimap": {
    "thumb_border": "none",
    "current_line_highlight": "none",
    "thumb": "hover",
    "show": "never",
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "search_results": true,
    "selected_text": true,
    "selected_symbol": true,
    "diagnostics": "error",
    "axes": {
      "horizontal": false,
      "vertical": true,
    },
  },
  "inline_code_actions": true,
  "gutter": {
    "min_line_number_digits": 3,
    "runnables": true,
    "folds": false,
    "breakpoints": true,
  },
  "autoscroll_on_clicks": false,
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "vertical_scroll_margin": 5,
  "git_panel": {
    "fallback_branch_name": "develop",
    "dock": "left",
    "sort_by_path": false,
    "status_style": "label_color",
    "button": true,
    "file_icons": true,
  },
  "icon_theme": "Symbols Icon Theme",
  "auto_update": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.DS_Store",
    "**/Thumbs.db"
  ],
  "calls": {
    "mute_on_join": true,
  },
  "git": {
    "blame": {
      "show_avatar": false,
    },
    "path_style": "file_path_first",
    "git_gutter": "tracked_files",
    "gutter_debounce": 250,
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "min_column": 5,
      "enabled": false,
      "show_commit_summary": false,
      "delay_ms": 5000,
    },
    "worktree_directory": ".git/zed-worktrees"
  },
  "base_keymap": "Atom",
  "disable_ai": false,
  "buffer_font_family": "CommitMono",
  "agent": {
    "sidebar_side": "right",
    "max_content_width": 750.0,
    "default_width": 550.0,
    "dock": "right",
    "show_turn_stats": true,
    "expand_terminal_card": false,
    "expand_edit_card": false,
    "thinking_display": "always_collapsed",
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.5",
        "enable_thinking": false,
      },
    ],
    "enable_feedback": false,
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "model_parameters": [],
  },
  "formatter": "language_server",
  "buffer_line_height": {
    "custom": 1.38,
  },
  "buffer_font_weight": 500.0,
  "ui_font_size": 18.0,
  "line_indicator_format": "long",
  "buffer_font_size": 20.0,
  "diagnostics": {
    "button": true,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "button_layout": "platform_default",
    "show_project_items": true,
    "show_branch_name": true,
    "show_menus": true,
    "show_onboarding_banner": false,
    "show_user_picture": true,
    "show_user_menu": true,
    "show_sign_in": true,
  },
  "debugger": {
    "button": false,
  },
  "terminal": {
    "show_count_badge": false,
    "cursor_shape": "block",
    "toolbar": {
      "breadcrumbs": true,
    },
    "minimum_contrast": 5.0,
    "blinking": "off",
    "scrollbar": {
      "show": "auto",
    },
    "copy_on_select": false,
    "font_weight": 500.0,
    "font_size": 18.0,
    "keep_selection_on_copy": false,
    "option_as_meta": false,
    "dock": "bottom",
    "default_height": 350,
    "max_scroll_history_lines": 10000,
    "working_directory": "current_file_directory",
    "detect_venv": "off",
    "env": {
      "EDITOR": "zed --wait",
    },
    "shell": {
      "program": "/bin/bash",
    },
  },
  "project_panel": {
    "dock": "left",
    "scrollbar": {
      "show": "auto",
    },
    "bold_folder_labels": false,
    "hide_hidden": false,
    "hide_root": true,
    "indent_guides": {
      "show": "never",
    },
    "show_diagnostics": "errors",
    "default_width": 350.0,
    "hide_gitignore": false,
    "auto_fold_dirs": false,
    "indent_size": 13.0,
    "starts_open": false,
    "sort_mode": "directories_first",
    "entry_spacing": "comfortable",
    "auto_reveal_entries": true,
    "git_status": true,
  },
  "excerpt_context_lines": 5,
  "edit_predictions_disabled_in": [
    "comment",
    "string"
  ],
  "active_pane_modifiers": {
    "inactive_opacity": 0.85,
  },
  "theme": "Ayu Dark",
  "lsp_document_colors": "inlay",
  "theme_overrides": {
    "Ayu Dark": {
      "syntax": {
        "property": {
          "color": "#E6E6E6FF",
          "font_style": null,
          "font_weight": null,
        },
        "string": {
          "color": "#23C5B0FF",
          "font_style": null,
          "font_weight": null,
        },
      },
      "border": "#363636FF",
      "border.selected": "#23C5B0FF",
      "elevated_surface.background": "#000000FF",
      "surface.background": "#000000FF",
      "background": "#000000FF",
      "element.background": "#000000FF",
      "element.active": "#1A1A1AFF",
      "element.selected": "#212121FF",
      "ghost_element.active": "#1A1A1AFF",
      "ghost_element.selected": "#212121FF",
      "text": "#E6E6E6FF",
      "text.muted": "#808080FF",
      "text.accent": "#23C5B0FF",
      "icon.muted": "#8A8986FF",
      "icon.accent": "#23C5B0FF",
      "status_bar.background": "#000000FF",
      "title_bar.background": "#000000FF",
      "title_bar.inactive_background": "#000000FF",
      "toolbar.background": "#000000FF",
      "tab_bar.background": "#000000FF",
      "tab.inactive_background": "#000000FF",
      "tab.active_background": "#0F0F0FFF",
      "panel.background": "#000000FF",
      "editor.background": "#000000FF",
      "editor.gutter.background": "#000000FF",
      "editor.subheader.background": "#000000FF",
      "editor.active_line.background": "#1A1A1AFF",
      "editor.highlighted_line.background": "#1A1A1AFF",
      "editor.active_line_number": "#E6E6E6FF",
      "editor.hover_line_number": "#E6E6E6FF",
      "editor.line_number": "#333333FF",
      "terminal.background": "#000000FF",
      "link_text.hover": "#23C5B0FF",
      "panel.overlay_background": "#000000FF",
      "panel.overlay_hover": "#000000FF",
      "version_control.added": "#27A657FF",
      "created": "#27A657FF",
      "version_control.modified": "#D3B020FF",
      "modified": "#D3B020FF",
      "renamed": "#D3B020FF",
      "version_control.word_added": "#2EA04859",
      "version_control.word_deleted": "#BD332AFF",
      "version_control.deleted": "#BD332AFF",
      "conflict": "#BD332AFF",
      "deleted": "#BD332AFF",
    },
  },
  "auto_install_extensions": {
    "codeowners": true,
    "comment": true,
    "csv": true,
    "deno": true,
    "desktop": true,
    "dockerfile": true,
    "git-firefly": true,
    "html": true,
    "ini": true,
    "log": true,
    "make": true,
    "nunjucks": true,
    "python-requirements": true,
    "symbols": true,
    "sql": true,
    "toml": true,
    "just": true,
    "env": true,
    "postgres-language-server": true
  },
  "lsp": {
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [
            {
              "fileMatch": [
                "deno.json",
                "deno.jsonc"
              ],
              "url": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
            },
            {
              "fileMatch": [
                "package.json"
              ],
              "url": "https://www.schemastore.org/package",
            },
          ],
        },
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": [
            {
              "fileMatch": [
                ".github/*.yml",
                ".github/**/*.yml"
              ],
              "url": "https://www.schemastore.org/github-workflow",
            },
            {
              "fileMatch": [
                "docker-compose.yml"
              ],
              "url": "https://raw.githubusercontent.com/compose-spec/compose-go/master/schema/compose-spec.json",
            },
          ],
        },
      },
    },
  },
}